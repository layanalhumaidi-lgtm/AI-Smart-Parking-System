<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    android:orientation="vertical"
    android:layoutDirection="rtl"
    android:textDirection="rtl">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:paddingHorizontal="20dp"
        android:background="#FFFFFF"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#333333" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="تعديل بيانات المستخدم"
            android:textColor="#333333"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Email Field (Disabled) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="البريد الإلكتروني "
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#888888"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etEditEmail"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/input_background"
            android:paddingHorizontal="16dp"
            android:textColor="#888888"
            android:textSize="15sp"
            android:enabled="false"
            android:layout_marginBottom="20dp"/>

        <!-- Full Name Field -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="الاسم الكامل"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etEditName"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/input_background"
            android:hint="أدخل اسم المستخدم"
            android:paddingHorizontal="16dp"
            android:inputType="textPersonName"
            android:textColor="#333333"
            android:textSize="15sp"
            android:layout_marginBottom="20dp"/>

        <!-- Phone Number Field -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="رقم الجوال"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etEditPhone"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/input_background"
            android:hint="05xxxxxxxx"
            android:paddingHorizontal="16dp"
            android:inputType="phone"
            android:textColor="#333333"
            android:textSize="15sp"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btnSaveChanges"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="حفظ التعديلات"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="@color/second_color"
            app:cornerRadius="12dp" />

    </LinearLayout>
</LinearLayout>