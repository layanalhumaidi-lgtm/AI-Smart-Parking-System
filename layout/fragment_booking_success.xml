<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:layoutDirection="rtl"
    android:textDirection="rtl"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Checkmark Circle -->
        <androidx.cardview.widget.CardView
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardCornerRadius="40dp"
            app:cardElevation="6dp"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="16dp">
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/parking_card_gradient_1" />
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="center"
                android:src="@drawable/success"
                app:tint="#FFFFFF" />
        </androidx.cardview.widget.CardView>

        <!-- Titles -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="تم الحجز بنجاح!"
            android:textColor="#1A1A1A"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="تم تأكيد حجزك ومعالجة الدفع بنجاح"
            android:textColor="#888888"
            android:textSize="14sp"
            android:layout_marginBottom="24dp"/>

        <!-- Receipt Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Header of Receipt -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:text="إيصال الحجز"
                        android:textColor="#333333"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvReceiptId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:text="#TPS-2024-001234"
                        android:textColor="#999999"
                        android:textSize="12sp"
                        android:layoutDirection="ltr"/>
                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginBottom="16dp"/>

                <!-- Details Rows -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="الموقع" android:textColor="#888888"/>
                    <TextView android:id="@+id/tvSuccessParkingName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="موقف جامعة الطائف" android:textColor="#333333" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="رقم الموقف" android:textColor="#888888"/>
                    <TextView android:id="@+id/tvSuccessSpot" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="A7" android:textColor="#D97A9A" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="التاريخ" android:textColor="#888888"/>
                    <TextView android:id="@+id/tvSuccessDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="05 ديسمبر 2024" android:textColor="#333333" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="الوقت" android:textColor="#888888"/>
                    <TextView android:id="@+id/tvSuccessTime" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="09:30 صباحاً" android:textColor="#333333" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="24dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="المدة" android:textColor="#888888"/>
                    <TextView android:id="@+id/tvSuccessDuration" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2 ساعات" android:textColor="#333333" android:textStyle="bold"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#EEEEEE" android:layout_marginBottom="20dp"/>

                <!-- Total -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="24dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="المبلغ المدفوع" android:textColor="#888888" android:textSize="16sp"/>
                    <TextView android:id="@+id/tvSuccessTotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="30 ر.س" android:textColor="#D97A9A" android:textStyle="bold" android:textSize="18sp"/>
                </LinearLayout>

                <!-- تم التعديل هنا: إضافة أيقونة لتستقبل صورة الـ QR Code الحقيقية -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_dashed_border"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <ImageView
                        android:id="@+id/ivQRCode"
                        android:layout_width="140dp"
                        android:layout_height="140dp"
                        android:layout_marginBottom="8dp"
                        android:scaleType="fitCenter"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="رمز QR للدخول"
                        android:textColor="#888888"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="احتفظ بهذا الرمز للدخول والخروج من الموقف"
                    android:textColor="#AAAAAA"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Buttons -->
        <Button
            android:id="@+id/btnViewDetails"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="عرض التفاصيل"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#D97A9A"
            app:cornerRadius="16dp"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnNavigateToSpot"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="التوجيه إلى الموقف"
            android:textColor="#C5A36F"
            android:textStyle="bold"
            android:backgroundTint="#FFFFFF"
            app:strokeColor="#C5A36F"
            app:strokeWidth="1dp"
            app:cornerRadius="16dp"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>