<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="60dp"
    android:gravity="center_horizontal"
    android:layoutDirection="rtl"
    android:textDirection="rtl">

    <!-- Admin Icon (Blue Tone) -->
    <androidx.cardview.widget.CardView
        android:layout_width="190dp"
        android:layout_height="190dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="22dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="#F0F4F8">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="20dp"
            android:src="@drawable/admin"
            />
    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="بوابة الإدارة"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:layout_marginBottom="8dp" />


    <!-- Admin Email -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="البريد الإلكتروني للإدارة"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:background="@drawable/input_background"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="16dp">
        <EditText
            android:id="@+id/etAdminEmail"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="ادخل بريدك الالكترونى"
            android:text="admin@smart.com"
            android:background="@android:color/transparent"
            android:inputType="textEmailAddress"
            android:textColor="#333333"
            android:textSize="15sp" />
        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@android:drawable/ic_dialog_email"
            app:tint="#607D8B" />
    </LinearLayout>

    <!-- Admin Password -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="كلمة المرور"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:background="@drawable/input_background"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="32dp">
        <EditText
            android:id="@+id/etAdminPassword"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="ادخل كلمة السر"
            android:text="123456"
            android:background="@android:color/transparent"
            android:inputType="textPassword"
            android:textColor="#333333"
            android:textSize="15sp" />
        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@android:drawable/ic_lock_idle_lock"
            app:tint="#607D8B" />
    </LinearLayout>

    <Button
        android:id="@+id/btnAdminLogin"
        android:layout_width="match_parent"
        android:layout_height="58dp"
        android:text="تسجيل الدخول"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="@color/second_color"
        android:elevation="0dp"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/tvBackToUserLogin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="العودة لتسجيل دخول المستخدمين"
        android:textColor="#607D8B"
        android:textStyle="bold"
        android:padding="8dp" />
</LinearLayout>