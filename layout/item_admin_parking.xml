<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:layoutDirection="rtl">

        <!-- Parking Icon -->
        <androidx.cardview.widget.CardView
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="#E8F5E9"
            app:cardElevation="0dp"
            android:layout_marginEnd="12dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/parking_area"
                android:padding="12dp"
                />
        </androidx.cardview.widget.CardView>

        <!-- Parking Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvParkingTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="اسم الموقف"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#333333"/>

            <TextView
                android:id="@+id/tvParkingPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15 ر.س/ساعة"
                android:textSize="13sp"
                android:textColor="#D97A9A"
                android:layout_marginTop="4dp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvParkingCapacity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="50 موقف متاح"
                android:textSize="12sp"
                android:textColor="#666666"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Actions -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnEditParking"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/edit"

                android:layout_marginEnd="8dp"/>

            <ImageView
                android:id="@+id/btnDeleteParking"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/delete"
                />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>