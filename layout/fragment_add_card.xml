<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:layoutDirection="rtl"
    android:textDirection="rtl">

    <RelativeLayout
        android:id="@+id/headerAddCard"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:paddingHorizontal="20dp">

        <androidx.cardview.widget.CardView
            android:id="@+id/btnBackAddCard"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="#333333" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="إضافة بطاقة جديدة"
            android:textColor="#333333"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/headerAddCard"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Card Mockup Image -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            android:layout_marginBottom="32dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/header_gradient_bg"
                android:padding="24dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/credit_card"
                    android:layout_alignParentEnd="true"/>

                <TextView
                    android:id="@+id/tvMockCardNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="••••  ••••  ••••  ••••"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:letterSpacing="0.1"
                    android:layout_centerInParent="true"
                    android:layoutDirection="ltr"/>

                <TextView
                    android:id="@+id/tvMockCardName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="الاسم على البطاقة"
                    android:textColor="#EEEEEE"
                    android:textSize="14sp"
                    android:layout_alignParentBottom="true"
                    android:layout_alignParentStart="true"
                    android:textStyle="bold"
                    android:textAllCaps="true"/>
            </RelativeLayout>
        </androidx.cardview.widget.CardView>

        <!-- Form Fields -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="الاسم على البطاقة"
            android:textColor="#333333"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/etCardName"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/input_background"
            android:hint="أدخل الاسم"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:inputType="textPersonName"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="رقم البطاقة"
            android:textColor="#333333"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>
        <EditText
            android:id="@+id/etCardNumber"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/input_background"
            android:hint="0000 0000 0000 0000"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="16dp"
            android:inputType="number"
            android:maxLength="19" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="تاريخ الانتهاء"
                    android:textColor="#333333"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etCardExpiry"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/input_background"
                    android:hint="MM/YY"
                    android:paddingHorizontal="16dp"
                    android:inputType="date"
                    android:maxLength="5"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="رمز CVV"
                    android:textColor="#333333"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/etCardCVV"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/input_background"
                    android:hint="123"
                    android:paddingHorizontal="16dp"
                    android:inputType="numberPassword"
                    android:maxLength="3"/>
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnSaveCard"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="حفظ واستخدام البطاقة"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="18sp"
            android:backgroundTint="#D97A9A"
            app:cornerRadius="16dp"
            android:layout_marginTop="32dp"/>
    </LinearLayout>
</RelativeLayout>